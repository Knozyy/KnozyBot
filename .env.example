# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Server ID
TARGET_GUILD_ID=your_discord_server_id_here

# KnozySunucu Panel Integration
# Ubuntu sunucusunda çalışıyorsa: http://localhost:3001
# Remote sunucuda: http://IP:3001
PANEL_URL=http://localhost:3001
PANEL_API_TOKEN=knozy_bot_token_here

# ByNoGame Bağış Sistemi (boş bırakılırsa sistem devre dışı kalır)
# Botun bağışları okuduğu liste sayfası
BYNO_DONATE_LIST_URL=https://donate.bynogame.com/donatelist/your-uuid-here
# Kullanıcılara gösterilen bağış sayfası
BYNO_PUBLIC_DONATE_URL=https://donate.bynogame.com/your-slug-here

# Environment
NODE_ENV=production

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bot.log
